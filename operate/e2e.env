# E2E Voice Test - additional environment variables
# These supplement the main .env file for the e2e test UEs.
# UERANSIM init scripts read UE1_* and UE2_* variables directly.

# UE1 for e2e test (caller)
UE1_IMSI=001011234567891
UE1_KI=465B5CE8B199B49FAA5F0A2EE238A6BC
UE1_OPC=2E001F1DF0A0BB769940A2C6342CF795
UE1_AMF=8000
UE1_IMEI=356938035643811
UE1_IMEISV=4370816125816111
UE1_MSISDN=0100001111
UE1_IP=172.22.0.50

# UE2 for e2e test (callee)
UE2_IMSI=001011234567892
UE2_KI=0986ED83D608930F0E29FDA1B51C5D58
UE2_OPC=B1EB2DA6D82D146F784FEDCE12BD3A79
UE2_AMF=8000
UE2_IMEI=356938035643822
UE2_IMEISV=4370816125816122
